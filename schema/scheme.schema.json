{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://color.recipes/schema/scheme.schema.json",
  "title": "Color Scheme",
  "description": "A single curated color scheme stored as schemes/<slug>.json (SPEC §6).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "tags", "colors", "source", "createdAt"],
  "properties": {
    "version": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$",
        "maxLength": 32
      }
    },
    "colors": {
      "type": "array",
      "minItems": 2,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^#[0-9a-fA-F]{6}$"
      }
    },
    "source": {
      "enum": ["ai", "manual"]
    },
    "createdAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
